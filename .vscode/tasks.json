{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode-extension",
      "label": "npm: watch - vscode-extension",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": ["relative", "${workspaceFolder}/vscode-extension"],
        "pattern": {
          "regexp": "✘ \\[ERROR\\] (.+)",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\]",
          "endsPattern": "Watching for changes\\.\\.\\."
        }
      },
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
